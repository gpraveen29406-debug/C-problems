bool isPrime(int n) {
    if (n < 2) return false;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0)
            return false;
    }
    return true;
}

int countPrimeSetBits(int left, int right) {
    int ans = 0;

    for (int i = left; i <= right; i++) {
        int num = i;
        int bits = 0;

        while (num) {
            bits += num & 1;
            num >>= 1;
        }

        if (isPrime(bits))
            ans++;
    }

    return ans;
}
