bool judgeCircle(char *moves) {
    int x = 0, y = 0;

    while (*moves) {
        switch (*moves) {
            case 'U':
                y++;
                break;
            case 'D':
                y--;
                break;
            case 'L':
                x--;
                break;
            case 'R':
                x++;
                break;
        }
        moves++;
    }

    return (x == 0 && y == 0);
}
