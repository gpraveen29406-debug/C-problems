#include <stdio.h>
int main() {
    int classType, weight, charge = 0;
    scanf("%d %d", &classType, &weight);

    switch(classType) {
        case 1:
            charge = weight * 300;
            break;

        case 2:
            if(weight <= 3)
                charge = 0;
            else
                charge = (weight - 3) * 300;
            break;
    }

    if(charge == 0)
        printf("Free");
    else
        printf("Extra Baggage Charge ₹%d", charge);

    return 0;
}
